// source/_data/styles.styl

.word-tts-container {
  display: inline-flex;
  align-items: center;
  cursor: pointer;
  position: relative;
  border-bottom: 1px dashed #ccc; 
  padding: 0 2px;
  border-radius: 2px;
}

.tts-icon {
  margin-left: 4px;
  font-size: 0.9em;
  color: #666; /* 替换 $grey-dim */
  transition: color 0.2s;
  
  &:hover {
    color: #007bff; /* 替换 $blue */
  }
}

.word-tts-container.playing {
  background-color: #e6f2ff; /* 添加背景色以便看到高亮 */
  border-bottom: 1px solid transparent;
}

